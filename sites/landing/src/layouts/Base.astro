---
import '../styles/global.css';

interface Props {
    title: string;
    description?: string;
    activePage?: string;
}

const { title, description = 'A compounding knowledge base built by LLMs.', activePage = '' } = Astro.props;
---

<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LLM Wiki | Build a Personal Knowledge Base with AI and Obsidian</title>
    <meta name="description" content="LLM Wiki is an open source personal knowledge engine. Claude Code ingests your sources, builds a persistent wiki, and keeps it current. Obsidian is where you browse it. Inspired by Karpathy's LLM Wiki pattern.">
    <meta property="og:title" content="LLM Wiki | Personal Knowledge Engine Powered by LLMs">
    <meta property="og:description" content="An open source system that turns articles, PDFs, YouTube videos, and tweets into a compounding knowledge base. Claude Code writes your wiki. Obsidian is where you read it.">
    <meta property="og:image" content="https://ronancodes.github.io/llm-wiki/assets/og-image.png">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://ronancodes.github.io/llm-wiki/">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="https://ronancodes.github.io/llm-wiki/assets/og-image.png">
</head>
<body>
<nav>
    <div class="nav-inner">
        <a href="/llm-wiki/" class="nav-brand">LLM <span>Wiki</span></a>
        <button class="nav-toggle" onclick="toggleNav()" aria-label="Menu">&#9776;</button>
        <div class="nav-links">
            <a href="/llm-wiki/" class:list={[{ active: activePage === 'home' }]}>Home</a>
            <a href="/llm-wiki/getting-started" class:list={[{ active: activePage === 'getting-started' }]}>Get Started</a>
            <a href="/llm-wiki/features" class:list={[{ active: activePage === 'features' }]}>Features</a>
            <a href="/llm-wiki/architecture" class:list={[{ active: activePage === 'architecture' }]}>Architecture</a>
            <a id="docs-link" href="/llm-wiki/docs/" class:list={[{ active: activePage === 'docs' }]}>Docs</a>
            <a href="https://github.com/RonanCodes/llm-wiki" target="_blank" class="gh">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                GitHub
            </a>
            <button class="theme-btn" id="theme-btn" onclick="toggleTheme()">&#9790; Dark</button>
        </div>
    </div>
</nav>

<div class="page">
<main>
    <slot />
</main>

<footer>
    <div class="container">
        <div class="footer-links">
            <a href="https://github.com/RonanCodes/llm-wiki" target="_blank">GitHub</a>
            <a href="https://gist.github.com/karpathy/442a6bf555914893e9891c11519de94f" target="_blank">Karpathy's Gist</a>
            <a href="/llm-wiki/getting-started">Get Started</a>
            <a href="/llm-wiki/features">Features</a>
            <a href="/llm-wiki/architecture">Architecture</a>
            <a class="docs-link-footer" href="/llm-wiki/docs/">Docs</a>
        </div>
        <div class="credit">Built with Claude Code. MIT License.</div>
    </div>
</footer>
</div>

<script>
import mediumZoom from 'medium-zoom';
document.addEventListener('DOMContentLoaded', () => {
    mediumZoom('img.preview-img', { background: 'var(--void)' });
});
</script>

<script is:inline>
var themeOrder = ['dark', 'light', 'auto'];
var themeLabels = { dark: '&#9790; Dark', light: '&#9728; Light', auto: '&#9881; Auto' };
function toggleTheme() {
    var html = document.documentElement;
    var current = localStorage.getItem('llm-wiki-theme') || 'dark';
    var next = themeOrder[(themeOrder.indexOf(current) + 1) % 3];
    localStorage.setItem('llm-wiki-theme', next);
    applyTheme(next);
}
function applyTheme(pref) {
    var actual = pref;
    if (pref === 'auto') actual = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', actual);
    var btn = document.getElementById('theme-btn');
    if (btn) btn.innerHTML = themeLabels[pref];
}
function toggleNav() {
    document.querySelector('.nav-links').classList.toggle('open');
}
(function() {
    var saved = localStorage.getItem('llm-wiki-theme') || 'auto';
    applyTheme(saved);
    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function() {
        if (localStorage.getItem('llm-wiki-theme') === 'auto') applyTheme('auto');
    });

    // In local dev, Starlight runs on port 4322
    if (window.location.hostname === 'localhost') {
        const docsLink = document.getElementById('docs-link');
        if (docsLink) docsLink.href = 'http://localhost:4322/llm-wiki/docs/';
        document.querySelectorAll('.docs-link-footer').forEach(a => a.href = 'http://localhost:4322/llm-wiki/docs/');
    }
})();
</script>
</body>
</html>
