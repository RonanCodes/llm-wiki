{
  "$schema": "https://agentskills.io/schema/v1",
  "name": "llm-wiki",
  "description": "Skills manifest for the LLM Wiki knowledge base system",
  "bundled": {
    "description": "Skills included in this repo (.claude/skills/). Available immediately.",
    "skills": [
      "vault-create",
      "vault-import",
      "vault-status",
      "ingest",
      "ingest-web",
      "ingest-pdf",
      "ingest-office",
      "ingest-youtube",
      "ingest-tweet",
      "ingest-gist",
      "ingest-text",
      "wiki-templates",
      "query",
      "search",
      "lint",
      "promote",
      "slides",
      "ralph",
      "setup",
      "create-skill",
      "read-tweet",
      "read-gist",
      "yt-transcript",
      "frontend-design"
    ]
  },
  "recommended": {
    "description": "Optional skills from external sources. /setup will check and suggest these.",
    "skills": [
      {
        "name": "write-a-prd",
        "source": "github:mattpocock/skills/write-a-prd",
        "description": "Create PRDs through user interview and codebase exploration",
        "install": "Clone to ~/.claude/skills/write-a-prd or add via --add-dir"
      },
      {
        "name": "grill-me",
        "source": "github:mattpocock/skills/grill-me",
        "description": "Interview the user to refine requirements before building",
        "install": "Clone to ~/.claude/skills/grill-me or add via --add-dir"
      },
      {
        "name": "tdd",
        "source": "github:mattpocock/skills/tdd",
        "description": "Test-driven development workflow",
        "install": "Clone to ~/.claude/skills/tdd or add via --add-dir"
      }
    ]
  },
  "tools": {
    "description": "External tools used by skills. Lazy-installed on first use.",
    "required": [
      { "name": "git", "check": "git --version", "install": "brew install git" },
      { "name": "node", "check": "node --version", "install": "brew install node" },
      { "name": "claude", "check": "claude --version", "install": "npm i -g @anthropic-ai/claude-code" }
    ],
    "optional": [
      { "name": "yt-dlp", "check": "which yt-dlp", "install": "brew install yt-dlp", "usedBy": "ingest-youtube" },
      { "name": "pdftotext", "check": "which pdftotext", "install": "brew install poppler", "usedBy": "ingest-pdf" },
      { "name": "pandoc", "check": "which pandoc", "install": "brew install pandoc", "usedBy": "ingest-office" },
      { "name": "qmd", "check": "which qmd", "install": "brew install qmd", "usedBy": "search" },
      { "name": "marp", "check": "which marp", "install": "pnpm add -g @marp-team/marp-cli", "usedBy": "slides" }
    ]
  }
}
