---
interface Props {
    title?: string;
}
const { title = 'terminal' } = Astro.props;
---

<div class="specimen">
    <div class="specimen-bar">
        <span class="specimen-dot"></span>
        <span class="specimen-dot"></span>
        <span class="specimen-dot"></span>
        <span class="specimen-title">{title}</span>
    </div>
    <div class="specimen-body"><slot /></div>
</div>
