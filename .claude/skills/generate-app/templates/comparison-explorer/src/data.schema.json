{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Comparison Explorer Data",
  "type": "object",
  "required": ["title", "topic", "generated_at", "columns", "rows"],
  "properties": {
    "title": { "type": "string" },
    "topic": { "type": "string" },
    "generated_at": { "type": "string" },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "label"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string" }
        }
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "summary", "values"],
        "properties": {
          "name": { "type": "string" },
          "source": { "type": "string", "description": "Relative path to the wiki page" },
          "summary": { "type": "string" },
          "values": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
