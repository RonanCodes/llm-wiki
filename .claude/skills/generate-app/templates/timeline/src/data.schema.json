{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Timeline Data",
  "type": "object",
  "required": ["title", "topic", "generated_at", "events"],
  "properties": {
    "title": { "type": "string" },
    "topic": { "type": "string" },
    "generated_at": { "type": "string" },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["date", "title", "source", "summary"],
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2}){0,2}$",
            "description": "YYYY, YYYY-MM, or YYYY-MM-DD. Sorts lexically."
          },
          "title": { "type": "string" },
          "source": { "type": "string", "description": "Relative path to the wiki page" },
          "summary": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
