# Vaults (each is its own repo)
vaults/*
!vaults/.gitkeep

# Private overlay (your own git repo for private skills/config)
.private/

# Private/local skills (any skill with .local in the name)
.claude/skills/*.local/
.claude/skills/*.local.*

# Skip plugin check (created by "don't ask again" option)
.claude/skip-plugin-check

# Claude Code local settings (contains machine-specific paths)
.claude/settings.local.json

# Claude Code runtime locks
.claude/scheduled_tasks.lock

# Reference repos (cloned for study)
/.reference/

# Local-factory artefacts (Ralph / planner-worker / night-shift, etc).
# See ~/Dev/ronan-skills/skills/ralph/SKILL.md § "Run artefacts (the canonical shape)".
# patterns.md and *.session.md stay tracked; everything else under .ralph/ is ephemeral.
.ralph/sessions/*/
.ralph/*.progress.txt
.ralph/.gitignore-policy

# Build output (generated by GitHub Actions, not committed)
/docs/

# Generated root-level portal (references private vault names — never commit)
/portal/

# Dependencies
node_modules/

# Next.js
.next/
out/

# Environment (project-level and per-skill)
.env
.env.local
.env.production
**/.env
**/.env.local

# Tasks/questions (local working state)
TASKS.md

# Playwright MCP (browser automation local state)
.playwright-mcp/

# OS
.DS_Store

# Docker
.docker/
sites/*/node_modules/
social-cards/

# Local bridge contract for external skills (vault names are private)
bridge.json

# Local-only notes (never commit work-context content)
CLAUDE.local.md
