# Vaults (each is its own repo)
vaults/*
!vaults/.gitkeep

# Private overlay (your own git repo for private skills/config)
.private/

# Private/local skills (any skill with .local in the name)
.claude/skills/*.local/
.claude/skills/*.local.*

# Skip plugin check (created by "don't ask again" option)
.claude/skip-plugin-check

# Claude Code local settings (contains machine-specific paths)
.claude/settings.local.json

# Reference repos (cloned for study)
/.reference/

# Ralph working files — policy: commit-all (see .ralph/.gitignore-policy)

# Build output (generated by GitHub Actions, not committed)
/docs/

# Dependencies
node_modules/

# Next.js
.next/
out/

# Environment (project-level and per-skill)
.env
.env.local
.env.production
**/.env
**/.env.local

# Tasks/questions (local working state)
TASKS.md

# OS
.DS_Store

# Docker
.docker/
sites/*/node_modules/
social-cards/
